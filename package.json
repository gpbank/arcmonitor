{
  "name": "arcmonitor",
  "version": "1.0.0",
  "description": "Arc Agent Monitor — tracks ERC-8004 agent registrations and agent-to-agent payments on Arc Network, sends Telegram alerts",
  "main": "monitor.js",
  "scripts": {
    "start": "node monitor.js",
    "bot": "node bot.js",
    "dev": "node --watch monitor.js",
    "test": "jest --config __tests__/jest.config.json",
    "test:contracts": "cd contracts && forge test -vvv",
    "test:all": "npm test && npm run test:contracts",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "keywords": [
    "arc",
    "erc-8004",
    "agent",
    "monitor",
    "telegram"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.34.1",
    "viem": "^2.22.16"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  }
}
